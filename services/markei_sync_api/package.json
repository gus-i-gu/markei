{
  "name": "@markei/sync-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint .",
    "lab": "tsx src/lab.ts",
    "lab:recovery": "tsx src/recovery_lab.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.3",
    "fastify": "^5.10.0",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "@types/pg": "8.15.6",
    "eslint": "9.39.1",
    "prettier": "3.6.2",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4"
  }
}
